// Prisma schema for the real-time chat application
// Run `npx prisma migrate dev --name init` after configuring DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// USERS
// ---------------------------------------------------------------------------
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String // bcrypt hash, never returned to client
  avatar    String? // URL to avatar image, nullable
  isOnline  Boolean  @default(false)
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[]
  messages     Message[]

  @@index([email])
  @@map("users")
}

// ---------------------------------------------------------------------------
// CONVERSATIONS
// One-to-one (and extensible to group) conversation container.
// ---------------------------------------------------------------------------
model Conversation {
  id        String   @id @default(uuid())
  isGroup   Boolean  @default(false)
  name      String? // used only for group chats
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[]
  messages     Message[]

  @@map("conversations")
}

// ---------------------------------------------------------------------------
// PARTICIPANTS
// Join table between User and Conversation.
// ---------------------------------------------------------------------------
model Participant {
  id             String   @id @default(uuid())
  userId         String
  conversationId String
  joinedAt       DateTime @default(now())

  // Tracks the last message this participant has read,
  // used to compute unread counts efficiently.
  lastReadAt DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId])
  @@index([userId])
  @@map("participants")
}

// ---------------------------------------------------------------------------
// MESSAGES
// ---------------------------------------------------------------------------
enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  status         MessageStatus @default(SENT)
  isRead         Boolean       @default(false)
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}
